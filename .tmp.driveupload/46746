  };

  function dedupeImageHistory(items: any[]): any[] {
    if (!Array.isArray(items)) return [];
    const seen = new Set<string>();
    return items.filter((item) => {
      const key = buildImageHistoryKey(item);
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });
  }

