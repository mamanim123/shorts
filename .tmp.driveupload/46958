<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>썸네일 성능 측정 도구</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      max-width: 900px;
      margin: 20px auto;
      padding: 20px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }
    .container {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }
    h1 {
      text-align: center;
      margin-bottom: 10px;
    }
    .subtitle {
      text-align: center;
      opacity: 0.8;
      margin-bottom: 30px;
    }
    .instructions {
      background: rgba(255, 255, 255, 0.2);
      padding: 20px;
      border-radius: 10px;
      margin-bottom: 20px;
    }
    .instructions ol {
      margin: 10px 0;
      padding-left: 25px;
    }
    .instructions li {
      margin: 8px 0;
    }
    .install-btn {
      display: block;
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      border: none;
      border-radius: 10px;
      color: white;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      margin-bottom: 20px;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .install-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
    }
    .results {
      background: rgba(0, 0, 0, 0.3);
      padding: 20px;
      border-radius: 10px;
      margin-top: 20px;
      display: none;
    }
    .results.show {
      display: block;
    }
    .metric {
      display: flex;
      justify-content: space-between;
      padding: 12px;
      margin: 8px 0;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      border-left: 4px solid #4ade80;
    }
    .metric.warning {
      border-left-color: #fbbf24;
    }
    .metric.error {
      border-left-color: #ef4444;
    }
    .metric-label {
      font-weight: bold;
    }
    .metric-value {
      font-family: 'Courier New', monospace;
      font-size: 18px;
    }
    .status {
      text-align: center;
      font-size: 14px;
      margin-top: 15px;
      opacity: 0.7;
    }
    code {
      background: rgba(0, 0, 0, 0.3);
      padding: 2px 6px;
      border-radius: 4px;
      font-family: 'Courier New', monospace;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🔍 사이드바 썸네일 성능 측정</h1>
    <p class="subtitle">실시간으로 썸네일 로딩 시간을 정확히 측정합니다</p>

    <div class="instructions">
      <h3>📋 사용 방법</h3>
      <ol>
        <li><strong>아래 "성능 측정 시작" 버튼 클릭</strong> → 메인 페이지에 성능 모니터 설치됨</li>
        <li><strong>메인 페이지로 이동</strong> (http://localhost:3000)</li>
        <li><strong>F12 → Console 탭 열기</strong></li>
        <li><strong>다음 순서대로 클릭하며 콘솔 확인:</strong>
          <ul>
            <li>① "보관함" 탭 클릭</li>
            <li>② "쇼츠 생성기" 탭 클릭</li>
            <li>③ 다시 "보관함" 클릭 → 대본 하나 클릭</li>
            <li>④ "쇼츠 생성기" → "보관함" 빠르게 3번 반복</li>
          </ul>
        </li>
        <li><strong>콘솔에서 <code>window.showResults()</code> 입력</strong></li>
      </ol>
    </div>

    <button class="install-btn" onclick="installMonitor()">
      🚀 성능 측정 시작 (메인 페이지에 설치)
    </button>

    <div id="results" class="results">
      <h3>📊 측정 결과</h3>
      <div id="metrics"></div>
      <div class="status">측정 완료! 위 결과를 확인하세요.</div>
    </div>

    <div class="instructions">
      <h3>✅ 정상 기준</h3>
      <ul>
        <li>첫 로딩: 500ms ~ 2000ms (썸네일 개수에 따라 다름)</li>
        <li>재방문: <strong>0ms ~ 100ms</strong> (즉시 표시)</li>
        <li>대본 클릭: <strong>0ms ~ 50ms</strong> (버벅거림 없음)</li>
      </ul>
      <h3>❌ 문제 있음</h3>
      <ul>
        <li>재방문 시 1000ms 이상: 계속 재로딩중 (최적화 실패)</li>
        <li>대본 클릭 시 500ms 이상: 버벅거림 (최적화 필요)</li>
      </ul>
    </div>
  </div>

  <script>
    function installMonitor() {
      const code = `
// 🔍 썸네일 성능 모니터 설치 완료!
console.clear();
console.log('%c🚀 썸네일 성능 측정 시작!', 'color: #4ade80; font-size: 20px; font-weight: bold;');
console.log('');

window.perfMetrics = {
  logs: [],
  startTime: performance.now(),
  loadCount: 0,
  lastAction: null
};

// 원본 console.log 저장
const originalLog = console.log;

// [Performance] 로그 인터셉트
console.log = function(...args) {
  const message = args.join(' ');
  
  if (message.includes('[Performance]')) {
    const elapsed = (performance.now() - window.perfMetrics.startTime).toFixed(0);
    
    if (message.includes('Loading')) {
      window.perfMetrics.loadCount++;
      window.perfMetrics.lastAction = 'loading';
      originalLog.call(console, 
        \`%c[\${elapsed}ms] 🔄 \${message}\`, 
        'color: #fbbf24; font-weight: bold;'
      );
      window.perfMetrics.logs.push({
        time: elapsed,
        action: 'thumbnail_load_start',
        message: message
      });
    } else if (message.includes('Loaded')) {
      originalLog.call(console, 
        \`%c[\${elapsed}ms] ✅ \${message}\`, 
        'color: #4ade80; font-weight: bold;'
      );
      window.perfMetrics.logs.push({
        time: elapsed,
        action: 'thumbnail_load_complete',
        message: message
      });
    } else {
      originalLog.call(console, 
        \`%c[\${elapsed}ms] ℹ️ \${message}\`, 
        'color: #60a5fa;'
      );
      window.perfMetrics.logs.push({
        time: elapsed,
        action: 'info',
        message: message
      });
    }
  } else {
    originalLog.apply(console, args);
  }
};

// 결과 보기 함수
window.showResults = function() {
  console.log('');
  console.log('%c📊 성능 측정 결과', 'color: #a78bfa; font-size: 18px; font-weight: bold;');
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  
  console.log(\`총 썸네일 로딩 횟수: \${window.perfMetrics.loadCount}회\`);
  
  if (window.perfMetrics.loadCount === 0) {
    console.log('%c🎉 완벽! 재로딩 없음', 'color: #4ade80; font-size: 16px; font-weight: bold;');
  } else if (window.perfMetrics.loadCount === 1) {
    console.log('%c✅ 정상! 초기 로딩만 발생', 'color: #4ade80; font-size: 16px;');
  } else if (window.perfMetrics.loadCount <= 2) {
    console.log('%c⚠️ 주의! 약간의 재로딩 발생', 'color: #fbbf24; font-size: 16px;');
  } else {
    console.log('%c❌ 문제! 과도한 재로딩', 'color: #ef4444; font-size: 16px; font-weight: bold;');
  }
  
  console.log('');
  console.log('상세 로그:');
  console.table(window.perfMetrics.logs);
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  
  return {
    loadCount: window.perfMetrics.loadCount,
    logs: window.perfMetrics.logs,
    totalTime: (performance.now() - window.perfMetrics.startTime).toFixed(0) + 'ms'
  };
};

console.log('');
console.log('%c✅ 설치 완료!', 'color: #4ade80; font-size: 16px; font-weight: bold;');
console.log('');
console.log('%c📌 이제 다음을 실행하세요:', 'color: #60a5fa; font-weight: bold;');
console.log('1. "보관함" 클릭');
console.log('2. "쇼츠 생성기" 클릭');
console.log('3. "보관함" → 대본 클릭');
console.log('4. 빠르게 탭 전환 반복');
console.log('');
console.log('%c5. 완료 후: window.showResults() 실행', 'color: #fbbf24; font-weight: bold;');
console.log('');
      `;

      // 클립보드에 복사
      navigator.clipboard.writeText(code).then(() => {
        alert('✅ 성능 모니터 코드가 클립보드에 복사되었습니다!\n\n다음 단계:\n1. 메인 페이지 (localhost:3000) 열기\n2. F12 → Console 탭\n3. Ctrl+V로 코드 붙여넣기\n4. Enter 키');
      });

      // 새 탭으로 메인 페이지 열기
      window.open('http://localhost:3000', '_blank');
    }
  </script>
</body>
</html>
