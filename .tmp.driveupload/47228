export const saveImageToDisk = async (imageData: string, prompt: string): Promise<string> => {
    try {
        const response = await fetch('http://localhost:3002/api/save-image', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ imageData, prompt })
        });
        const data = await response.json();
        if (data.success) return data.filename;
        throw new Error(data.error);
    } catch (e) {
        console.error("Failed to save image to disk", e);
        return "";
    }
};

