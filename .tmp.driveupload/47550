// [NEW] YouTube Analysis API (yt-dlp integration + ffmpeg + Whisper fallback)
const DOWNLOAD_TIMEOUT_MS = 3 * 60 * 1000; // 3 minutes
const WHISPER_TIMEOUT_MS = 10 * 60 * 1000; // 10 minutes
const MAX_TRANSCRIPT_LENGTH = 8000;
const SUB_LANGS = process.env.YT_SUB_LANGS || 'ko,en,en-US,en-GB,ja,zh-Hans,zh-Hant,es';
const SUB_LANGS_FALLBACK = process.env.YT_SUB_LANGS_FALLBACK || 'all';
const YTDLP_COOKIES_PATH = process.env.YTDLP_COOKIES || process.env.YTDLP_COOKIES_PATH || '';
const SUB_FORMATS = process.env.YT_SUB_FORMATS || 'vtt/srt/srv3/ttml/srv1/srv2';

function cleanTranscriptText(text = "") {
    return text
        .replace(/WEBVTT/gi, '')
        .replace(/(\d{2}:\d{2}:\d{2}\.\d{3} --> \d{2}:\d{2}:\d{2}\.\d{3})/g, '')
        .replace(/(\d{2}:\d{2}:\d{2},\d{3} --> \d{2}:\d{2}:\d{2},\d{3})/g, '')
        .replace(/<[^>]*>/g, '')
        .replace(/align:start position:0%/gi, '')
        .replace(/line:\d+%/gi, '')
        .replace(/^\s*[\r\n]/gm, '')
        .split('\n')
        .filter(line => !line.trim().match(/^\d+$/))
        .map(line => line.trim())
        .filter(Boolean)
        .join(' ')
        .trim();
}

async function downloadAudioForWhisper(url, tempId) {
    const tempBase = path.join(GENERATED_DIR, `temp_${tempId}`);
    const audioPattern = `${tempBase}.%(ext)s`;
    const cookiesArg = YTDLP_COOKIES_PATH ? ` --cookies "${YTDLP_COOKIES_PATH}"` : '';
    await execAsync(`yt-dlp -f bestaudio --no-playlist${cookiesArg} --output "${audioPattern}" "${url}"`, { timeout: DOWNLOAD_TIMEOUT_MS });
    const files = fs.readdirSync(GENERATED_DIR);
    const audioFile = files.find(f =>
        f.startsWith(`temp_${tempId}`) &&
        !f.endsWith('.vtt') &&
        !f.endsWith('.srt') &&
        !f.endsWith('.txt') &&
        !f.endsWith('.json')
    );
    if (!audioFile) throw new Error('Audio download failed');
    return path.join(GENERATED_DIR, audioFile);
}

async function convertToWav(inputPath, tempId) {
    const wavPath = path.join(GENERATED_DIR, `temp_${tempId}.wav`);
    await execAsync(`ffmpeg -y -i "${inputPath}" -ac 1 -ar 16000 -f wav "${wavPath}"`, { timeout: DOWNLOAD_TIMEOUT_MS });
    return wavPath;
}

async function transcribeWithLocalWhisper(wavPath, tempId) {
    const whisperBin = process.env.WHISPER_BIN || 'whisper';
    try {
        await execAsync(`command -v ${whisperBin}`);
    } catch {
        return null;
    }

    const baseName = `temp_${tempId}`;
    try {
        await execAsync(`${whisperBin} "${wavPath}" --model small --language ko --output_format txt --output_dir "${GENERATED_DIR}"`, { timeout: WHISPER_TIMEOUT_MS });
    } catch (e) {
        console.error('[Whisper] Local transcription failed:', e.message || e);
        return null;
    }

    const txtPath = path.join(GENERATED_DIR, `${baseName}.txt`);
    if (!fs.existsSync(txtPath)) return null;
    const raw = fs.readFileSync(txtPath, 'utf8');
    try { fs.unlinkSync(txtPath); } catch { }
    return cleanTranscriptText(raw);
}

async function transcribeWithOpenAI(wavPath) {
    // Disabled to avoid unintended API usage/costs. Enable by replacing this guard.
    return null;
}

async function whisperFallback(url, tempId) {
    const cleanupPaths = [];
    let errorMsg = null;
    try {
        const audioPath = await downloadAudioForWhisper(url, tempId);
        cleanupPaths.push(audioPath);
        const wavPath = await convertToWav(audioPath, tempId);
        cleanupPaths.push(wavPath);

        let transcript = await transcribeWithLocalWhisper(wavPath, tempId);
        let source = 'local-whisper';

        if (!transcript) {
            transcript = await transcribeWithOpenAI(wavPath);
            source = transcript ? 'openai-whisper' : source;
        }

        return { transcript, source, error: null };
    } catch (e) {
        console.error('[Whisper] Fallback failed:', e.message || e);
        errorMsg = e?.message || String(e);
        return { transcript: null, source: null, error: errorMsg };
    } finally {
        cleanupPaths.forEach(p => {
            try { fs.unlinkSync(p); } catch { }
        });
    }
}

app.post('/api/analyze-youtube', async (req, res) => {
    const { url } = req.body;
    if (!url) return res.status(400).json({ error: "URL is required" });

    try {
        console.log(`[Server] Analyzing YouTube URL: ${url}`);

        const cookiesArg = YTDLP_COOKIES_PATH ? ` --cookies "${YTDLP_COOKIES_PATH}"` : '';

        const metadataCmd = `yt-dlp --dump-json --no-playlist${cookiesArg} "${url}"`;
        const { stdout: metaStdout } = await execAsync(metadataCmd);
        const metadata = JSON.parse(metaStdout);

        const tempId = metadata.id;
        const tempPath = path.join(GENERATED_DIR, `temp_${tempId}`);

        try {
            const oldFiles = fs.readdirSync(GENERATED_DIR).filter(f => f.startsWith(`temp_${tempId}`));
            oldFiles.forEach(f => fs.unlinkSync(path.join(GENERATED_DIR, f)));
        } catch (e) { }

        const subtitleAttemptLogs = [];
        const downloadSubtitles = async (subLang) => {
            const formatArg = SUB_FORMATS ? ` --sub-format ${SUB_FORMATS}` : '';
            const subCmd = `yt-dlp --write-auto-sub --write-sub --convert-subs srt --sub-lang ${subLang}${formatArg} --skip-download --no-playlist${cookiesArg} --output "${tempPath}" "${url}"`;
            try {
                await execAsync(subCmd, { timeout: DOWNLOAD_TIMEOUT_MS });
                return true;
            } catch (err) {
                const msg = err?.message || String(err);
                subtitleAttemptLogs.push(`langs=${subLang}: ${msg}`);
                console.warn(`[Server] Subtitle download failed for langs "${subLang}", will try fallback:`, msg);
                return false;
            }
        };

        let subtitleDownloaded = await downloadSubtitles(SUB_LANGS);
        if (!subtitleDownloaded && SUB_LANGS_FALLBACK && SUB_LANGS_FALLBACK !== SUB_LANGS) {
            subtitleDownloaded = await downloadSubtitles(SUB_LANGS_FALLBACK);
        }

        const files = subtitleDownloaded ? fs.readdirSync(GENERATED_DIR) : [];
        const subFile = files.find(f => f.startsWith(`temp_${tempId}`) && (f.endsWith('.vtt') || f.endsWith('.srt')));

        let transcript = "";
        let transcriptSource = "subtitle";
        let whisperError = null;

        if (subFile) {
            const subContent = fs.readFileSync(path.join(GENERATED_DIR, subFile), 'utf8');
            transcript = cleanTranscriptText(subContent);
            try { fs.unlinkSync(path.join(GENERATED_DIR, subFile)); } catch { }
        }

        if (!transcript) {
            const fallback = await whisperFallback(url, tempId);
            if (fallback.transcript) {
                transcript = fallback.transcript;
                transcriptSource = fallback.source || "whisper";
                whisperError = fallback.error || null;
            } else {
                transcript = "(자막을 찾을 수 없습니다. 영상의 시각적 정보나 오디오를 분석해야 할 수 있습니다.)";
                transcriptSource = "none";
                whisperError = fallback.error || null;
            }
        }

        if (transcript.length > MAX_TRANSCRIPT_LENGTH) {
            transcript = transcript.slice(0, MAX_TRANSCRIPT_LENGTH) + ' ... (truncated)';
        }

        res.json({
            title: metadata.title,
            viewCount: metadata.view_count,
            likeCount: metadata.like_count,
            channel: metadata.uploader,
            duration: metadata.duration,
            transcript,
            transcriptSource,
            thumbnail: metadata.thumbnail,
            subtitleAttempts: subtitleAttemptLogs,
            whisperError
        });

    } catch (error) {
        console.error("[Server] YouTube Analysis Error:", error);
        res.status(500).json({ error: "Failed to analyze YouTube video. " + error.message });
    }
});

