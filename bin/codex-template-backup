#!/bin/bash
PROMPT_FILE="$(pwd)/.codex/prompts/template_backup.txt"
if [ ! -f "$PROMPT_FILE" ]; then
  echo "Prompt file not found: $PROMPT_FILE" >&2
  exit 1
fi
if [ $# -eq 0 ]; then
  echo "Usage: codex-template-backup <file1> [file2 ...]" >&2
  exit 1
fi
codex run --prompt-file "$PROMPT_FILE" "$@"
