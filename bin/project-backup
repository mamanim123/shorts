#!/bin/bash
set -euo pipefail
BASE_DIR="$(pwd)"
BACKUP_ROOT="${BASE_DIR}/backups/project-backups"
mkdir -p "$BACKUP_ROOT"
STAMP="$(date +%Y%m%d-%H%M%S)"
ARCHIVE_PATH="${BACKUP_ROOT}/${STAMP}-project-backup.zip"
# 백업 폴더 자체와 node_modules/.cache 등 불필요 폴더는 제외
zip -r "$ARCHIVE_PATH" . \
  -x "backups/project-backups/*" \
  -x "node_modules/.cache/*" \
  -x "*.png" -x "*.jpg" -x "*.jpeg" -x "*.gif" -x "*.webp" \
  -x "*.mp4" -x "*.mov" -x "*.avi" -x "*.mkv" -x "*.webm"
cat <<MSG
프로젝트 전체 백업 완료
- 백업 파일: $ARCHIVE_PATH
- 제외 항목: backups/project-backups, node_modules/.cache, 이미지/동영상 파일
필요 시 백업 파일을 다른 위치로 복사해 보관하세요.
MSG
