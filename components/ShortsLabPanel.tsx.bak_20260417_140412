        // 1. Update local state (UI immediate feedback)
        setMasterCharacterProfiles(prev => prev.map(p => {
            if (p.slotId !== slotId) return p;
            if (field === 'outfit') {
                return { ...p, outfit: value, outfitPrompt: value };
            }
            return { ...p, [field]: value };
        }));

        // 2. If outfit, update masterOutfitMap
        if (field === 'outfit') {
            const selectedOutfit = resolveOutfitEntry(value);
            setMasterOutfitMap(prev => {
                const newMap = new Map(prev);
                if (!selectedOutfit) {
                    newMap.delete(slotId);
                } else {
                    newMap.set(slotId, { name: selectedOutfit.name, prompt: selectedOutfit.prompt || selectedOutfit.name });
                }
                return newMap;
            });
        }

        if (field === 'name' || field === 'face' || field === 'hair' || field === 'body' || field === 'style' || field === 'skinTone' || field === 'signatureFeatures') {
            setCharacterCastings((prev) => {
                const existing = prev.get(slotId);
                if (!existing) return prev;
                const next = new Map(prev);
                const profile = masterCharacterProfiles.find((item) => item.slotId === slotId);
                const summary = [
                    field === 'face' ? value : (profile?.face || profile?.identity),
                    field === 'hair' ? value : profile?.hair,
                    field === 'body' ? value : profile?.body,
                    field === 'skinTone' ? value : profile?.skinTone,
                    field === 'signatureFeatures' ? value : profile?.signatureFeatures,
                    field === 'style' ? value : profile?.style,
                ].filter(Boolean).join(', ');
                next.set(slotId, {
                    ...existing,
                    name: field === 'name' ? value : existing.name,
                    identitySummary: summary || existing.identitySummary,
                });
                return next;
            });
        }

        // 3. Sync to Global Rules
        const gender = slotId.startsWith('Woman') ? 'female' : 'male';
        try {
            await updateCharacter(gender, slotId, { [field]: value });
        } catch (e) {
            console.error('Failed to sync character rule:', e);
        }
    };

