            const currentRules = getCharacterRules(); // 실시간으로 최신 규칙 가져오기
            if (currentRules) {
                const normalizedFemales = (currentRules.females || []).map((char) => ({
                    ...char,
                    id: typeof char.id === 'string'
                        ? char.id.replace(/^female/i, 'Woman').replace(/^male/i, 'Man').replace(/^(Woman|Man)([a-z])/, (_, prefix, letter) => prefix + letter.toUpperCase())
                        : char.id
                }));
                const normalizedMales = (currentRules.males || []).map((char) => ({
                    ...char,
                    id: typeof char.id === 'string'
                        ? char.id.replace(/^female/i, 'Woman').replace(/^male/i, 'Man').replace(/^(Woman|Man)([a-z])/, (_, prefix, letter) => prefix + letter.toUpperCase())
                        : char.id
                }));
                const allNormalized = [...normalizedFemales, ...normalizedMales];

                // 슬롯 ID가 일치하는 경우 의상 규칙의 데이터로 업데이트
                profiles = profiles.map(profile => {
                    const rule = allNormalized.find(r => r.id === profile.slotId);
                    if (rule) {
                        return {
                            ...profile,
                            characterId: rule.characterId || profile.characterId,
                            name: rule.name || profile.name,
                            identity: rule.identity || profile.identity,
                            face: rule.face || profile.face,
                            hair: rule.hair || profile.hair,
                            body: rule.body || profile.body,
                            style: rule.style || profile.style,
                            skinTone: rule.skinTone || profile.skinTone,
                            signatureFeatures: rule.signatureFeatures || profile.signatureFeatures
