                        profiles.push({
                            slotId: rule.id,
                            characterId: rule.characterId,
                            name: rule.name || '',
                            identity: rule.identity || '',
                            face: rule.face || '',
                            hair: rule.hair || '',
                            body: rule.body || '',
                            outfit: '',
                            outfitPrompt: '',
                            style: rule.style || '',
                            skinTone: rule.skinTone || '',
                            signatureFeatures: rule.signatureFeatures || ''
