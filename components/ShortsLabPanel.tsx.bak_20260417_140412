                        const updatedRules = await updateCharacterRules(rulesInput);
                        
                        // [FORCE SYNC] 의상 규칙의 상세 정보를 마스터 프로필(미리보기)에 즉시 강제 주입
                        const allCharacterRules = [...(updatedRules.females || []), ...(updatedRules.males || [])];
                        
                        setMasterCharacterProfiles(prev => {
                            const next = prev.map(profile => {
                                const rule = allCharacterRules.find(r => 
                                    (r.characterId && r.characterId === profile.characterId) || 
                                    (r.id === profile.slotId) ||
                                    (r.name && r.name === profile.name)
                                );
                                
                                if (!rule) return profile;

                                // 모든 상세 필드를 의상 규칙의 최신 값으로 덮어씀
                                return {
                                    ...profile,
                                    name: rule.name || profile.name,
                                    identity: rule.identity || profile.identity,
                                    face: rule.face || profile.face,
                                    hair: rule.hair || profile.hair,
                                    body: rule.body || profile.body,
                                    style: rule.style || profile.style,
                                    skinTone: rule.skinTone || profile.skinTone,
                                    signatureFeatures: rule.signatureFeatures || profile.signatureFeatures
                                };
                            });
                            return next;
                        });

                        // [SERVER SYNC] 서버의 캐릭터 정보(AI Studio 연동 데이터)도 상세 명세 업데이트
                        try {
                            const currentCharacters = await fetchCharacters();
                            const updatedCharacters = currentCharacters.map(char => {
                                const matchedRule = allCharacterRules.find(r => 
                                    (char.id && r.characterId === char.id) || 
                                    (char.name && r.name === char.name)
                                );
                                
                                if (!matchedRule) return char;

                                // 서버 데이터의 identitySpec을 의상 규칙의 상세 정보로 업데이트
                                return {
                                    ...char,
                                    name: matchedRule.name || char.name,
                                    face: matchedRule.face || char.face,
                                    hair: matchedRule.hair || char.hair,
                                    body: matchedRule.body || char.body,
                                    style: matchedRule.style || char.style,
                                    identitySpec: {
                                        ...char.identitySpec,
                                        faceShape: matchedRule.face || char.identitySpec?.faceShape,
                                        hairDescription: matchedRule.hair || char.identitySpec?.hairDescription,
                                        bodyType: matchedRule.body || char.identitySpec?.bodyType,
                                        styleCore: matchedRule.style || char.identitySpec?.styleCore,
                                        skinTone: matchedRule.skinTone || char.identitySpec?.skinTone,
                                        signatureFeatures: matchedRule.signatureFeatures || char.identitySpec?.signatureFeatures
                                    }
                                };
                            });
                            await saveCharacters(updatedCharacters);
                            
                            // 로컬 상태(savedCharacters)도 즉시 업데이트하여 오른쪽 패널 반영
                            setSavedCharacters(updatedCharacters);
                        } catch (err) {
                            console.error('[ShortsLab] Failed to sync detailed character rules to server:', err);
                        }

                        showToast('의상 규칙 및 캐릭터 상세 정보가 저장되었습니다.', 'success');
