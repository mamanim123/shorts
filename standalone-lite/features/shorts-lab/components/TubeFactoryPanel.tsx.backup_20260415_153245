    try {
      // Base64 лҚ°мқҙн„° м¶”м¶ң
      let base64Data = '';
      
      // standalone-liteм—җм„ңлҠ” referenceImage File к°қмІҙк°Җ мһҲмңјлҜҖлЎң мқҙлҘј мҡ°м„  мӮ¬мҡ©
